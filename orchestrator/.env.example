# ---- Phantasm orchestrator configuration ----
# Copy to `.env` and edit. All values are read at startup (NFR-O4).

# Address the orchestrator listens on (the only port exposed to the app).
PHANTASM_BIND=0.0.0.0:8080

# Bearer token the iOS app must send on every request. Leave unset or empty to
# DISABLE auth entirely (every request is accepted unauthenticated) — only do
# this on a trusted network. Set it to a long random secret to gate the server.
PHANTASM_AUTH_TOKEN=change-me-to-a-long-random-secret

# Browser CORS allow-list. Empty (default) => CORS off: no Access-Control-*
# headers and no preflight handling. The iOS app is not a browser and needs
# none, so leave this unset unless a web client calls the orchestrator directly.
# A single `*` allows any origin; otherwise a CSV of exact origins to allow.
# PHANTASM_CORS_ALLOWED_ORIGINS=https://chat.example,https://localhost:5173

# ---- Upstream model host ----
# auto probes native Ollama first, then OpenAI-compatible /v1. Set explicitly for
# hosts such as vLLM or llama.cpp to avoid accidental native-Ollama fallback.
# Accepted: auto, ollama, native_ollama, openai_compatible, vllm, llama_cpp.
UPSTREAM_KIND=auto
# Native Ollama usually runs at http://localhost:11434. vLLM commonly runs at
# http://localhost:8000; llama.cpp llama-server commonly runs at
# http://localhost:8080. If this URL does not already end in /v1, the
# OpenAI-compatible client appends /v1 automatically.
UPSTREAM_BASE_URL=http://localhost:11434
# Optional bearer token for OpenAI-compatible upstreams. Do not confuse this
# with PHANTASM_AUTH_TOKEN, which protects this orchestrator's public endpoint.
# UPSTREAM_API_KEY=sk-...
# Send the Qwen-style chat_template_kwargs.enable_thinking hint to an
# OpenAI-compatible upstream (vLLM/llama.cpp honor it to toggle thinking per
# request). Set false for a strict /v1 server that rejects unknown body fields.
UPSTREAM_THINKING_HINT=true
UPSTREAM_DEFAULT_MODEL=llama3.1
# Optional CSV of models to advertise. If unset, probed from /api/tags or /v1/models.
# UPSTREAM_MODELS=llama3.1,qwen2.5:14b
# Cap simultaneous upstream generations; the rest queue (NFR-O2).
UPSTREAM_MAX_CONCURRENCY=4
# Backward-compatible aliases still work: OLLAMA_BASE_URL,
# OLLAMA_DEFAULT_MODEL, OLLAMA_MODELS, OLLAMA_MAX_CONCURRENCY.
# Safety cap on the server-side tool loop (FR-O3).
MAX_TOOL_ITERS=5

# ---- Resumable turns. A streaming turn started with an `Idempotency-Key`
# ---- request header keeps running across client disconnects (e.g. the app
# ---- backgrounding) and is buffered server-side; a reconnect with the same key
# ---- replays it (resumes long image generations that outlive a foreground app).
# How long a finished turn's buffered output is kept for a late reconnect (s).
# Default 24h, so a reconnect recovers a generation even long after the app closed.
TURN_RESULT_TTL_S=86400
# Cap on simultaneously buffered turns (bounds worst-case memory).
TURN_REGISTRY_MAX=128
# How long a still-running turn may have no connected client before the watchdog
# cancels it (frees the GPU for a force-killed app). 0 disables the watchdog.
TURN_ABANDON_GRACE_S=300

# ---- Request guards (DoS surface). The body limit overrides axum's silent
# ---- 2 MiB default that rejects image-bearing histories with a 413. Lower the
# ---- body limit once the app references prior images by URL instead of
# ---- re-sending their base64 each turn.
# Max bytes for an entire request body (default 32 MiB).
MAX_REQUEST_BODY_BYTES=33554432
# Max inline images (attached + embedded data: URIs) per request (default 16).
MAX_REQUEST_IMAGES=16
# Max decoded bytes for a single inline image (default 16 MiB).
MAX_REQUEST_IMAGE_BYTES=16777216
# Longest edge (px) a vision input may have before it's downscaled on the way to
# Ollama (default 1536). Vision models cap resolution internally, so larger only
# wastes upload/memory/re-sent-history bytes.
IMAGE_MAX_DIMENSION=1536
# Only images whose source bytes exceed this are decoded + downscaled; smaller
# ones pass after a cheap magic-byte sniff (default 1 MiB).
IMAGE_DOWNSCALE_TRIGGER_BYTES=1048576
# Per-attempt timeout for fetching a remote (http/https) input image (default
# 10s). Remote URLs are fetched with SSRF guards (private/loopback/link-local
# IPs are refused) and subject to MAX_REQUEST_IMAGE_BYTES.
IMAGE_FETCH_TIMEOUT_MS=10000

# ---- Research mode presets. Research is selected by a mode-suffixed model id
# ---- (e.g. "qwen2.5:14b:deep-research"), resolved server-side against these
# ---- presets and advertised via /v1/capabilities "modes". Mode ids/labels are
# ---- fixed; these knobs tune each tier. (fanout/searches_per_subq/verify drive
# ---- the stage-3 engine; today they are carried but research behavior is the
# ---- legacy single-loop.)
RESEARCH_DEEP_FANOUT=4
RESEARCH_DEEP_SEARCHES_PER_SUBQ=3
RESEARCH_DEEP_VERIFY=true
RESEARCH_QUICK_FANOUT=2
RESEARCH_QUICK_SEARCHES_PER_SUBQ=2
RESEARCH_QUICK_VERIFY=false
# Max sub-questions researched in parallel (stage-3 fan-out concurrency). This
# is a SOFT scheduling hint: it bounds how many sub-agents are polled at once,
# but every research upstream call (plan, each sub-agent search, compress,
# synth, verify) re-acquires UPSTREAM_MAX_CONCURRENCY, so the global bound — not
# this knob — is the real ceiling on concurrent upstream work (NFR-O2). A research
# turn therefore never over-subscribes the GPU regardless of this value.
RESEARCH_FANOUT_CONCURRENCY=2

# ---- Web search tool (Brave). Optional; disabled if no key. ----
TOOL_WEB_SEARCH=false
# BRAVE_API_KEY=your-brave-search-api-key
BRAVE_BASE_URL=https://api.search.brave.com
SEARCH_MAX_RESULTS=5
# Overall char cap for an ordinary (non-research) search turn's tool output.
SEARCH_CONTEXT_CHARS=4000
# Per-PAGE extract cap when fetching full pages, independent of result count.
# (Replaces the old SEARCH_CONTEXT_CHARS/results-count split that starved each
# page to ~800 chars in a 5-result search.)
SEARCH_PAGE_CHARS=2500
# Overall char cap for a RESEARCH search turn — larger than SEARCH_CONTEXT_CHARS
# so a sub-agent reading several pages for one sub-question is not starved.
RESEARCH_CONTEXT_CHARS=12000
# Permit the model to request a "thorough" search (depth="thorough"), which
# fetches and extracts full result pages. Off by default: every search stays
# snippet-only and fast. When on, the model still picks per query, so simple
# lookups stay quick and only research/comparison queries pay the fetch cost.
SEARCH_FETCH_PAGES=false
SEARCH_FETCH_CONCURRENCY=3
SEARCH_FETCH_TIMEOUT_MS=1500

# ---- Additional read-only tools. Optional; disabled unless toggled on. ----
# User-Agent sent to public tool APIs. Set this to include contact info if you
# run against public Nominatim or other services that request identifiable UA.
TOOL_HTTP_USER_AGENT=Phantasm/0.1.0 self-hosted

# Fetch and extract a specific HTTP(S) page. Blocks local/private IP literals and
# non-HTTP schemes; fetched text is only returned to the active turn.
TOOL_WEB_FETCH=false
WEB_FETCH_CONTEXT_CHARS=8000

# Pure local utility tools; no network and no filesystem access.
TOOL_CALCULATOR=false
TOOL_TIME=false
TOOL_UNIT_CONVERT=false

# Weather via Open-Meteo (no key required).
TOOL_WEATHER=false
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OPEN_METEO_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com

# Sports scores/schedules via ESPN's public scoreboard API (no key required).
TOOL_SPORTS=false
ESPN_API_BASE_URL=https://site.api.espn.com

# Places/geocoding via Nominatim (geocoding) + Overpass (POI search around a
# point). A category-near-location query geocodes the location with Nominatim,
# then asks Overpass for nearby POIs. For heavy use, self-host both and point
# NOMINATIM_BASE_URL / OVERPASS_BASE_URL at them; the public instances are
# rate-limited.
TOOL_MAPS_PLACES=false
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_BASE_URL=https://overpass-api.de

# Market quotes via Alpha Vantage. Disabled unless both toggle and key are set.
TOOL_MARKET_DATA=false
# ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co

# Read-only GitHub REST API access. Token is optional for public endpoints but
# recommended for rate limit and code search reliability.
TOOL_GITHUB=false
GITHUB_API_BASE_URL=https://api.github.com
# GITHUB_TOKEN=github_pat_...
GITHUB_CONTEXT_CHARS=8000

# OCR via local tesseract. Uses a request-scoped temp file for process handoff
# and deletes it when the call finishes; no durable OCR storage.
TOOL_OCR=false
TESSERACT_BIN=tesseract
OCR_TIMEOUT_S=20
OCR_CONTEXT_CHARS=8000

# ---- Code execution. Runs untrusted, model-authored code in a per-execution
# ---- hardened container (default rootless podman). A warm pool of pre-started
# ---- containers is kept ready; each container serves exactly ONE run and is then
# ---- destroyed + replaced, so nothing leaks between runs. Requires the runtime
# ---- binary and the sandbox image (build it from docker/code-exec/).
# ----
# ---- There is ONE `code_exec` tool with two network lanes, chosen per turn by the
# ---- app's "Web access" toggle (no app changes needed — it sits in both the
# ---- utilities and web-access tool buckets):
# ----   * web access OFF -> runs with `--network none` (no internet at all)
# ----   * web access ON  -> runs with internet via CODE_EXEC_NETWORK (below)
# ---- Note: the ON lane is only selected when the turn also includes another web
# ---- tool (web_search, weather, ...) as the signal; if code-exec is your ONLY web
# ---- feature, runs stay offline. See docker/code-exec/README.md.
TOOL_CODE_EXEC=false
# Container CLI: "podman" (rootless, recommended) or "docker". Identical flags.
CODE_EXEC_RUNTIME=podman
# Universal sandbox image (build: docker/code-exec/Dockerfile).
CODE_EXEC_IMAGE=phantasm/code-exec:latest
# Languages the deployed image can run. Feeds the tool's schema enum. v1 supports
# interpreted languages only.
CODE_EXEC_LANGUAGES=python,node,bash,ruby
# Network for the ONLINE lane: a preconfigured network with an egress firewall that
# DROPs traffic to private ranges (10/8, 172.16/12, 192.168/16), localhost (127/8),
# and the cloud metadata IP (169.254.0.0/16) while allowing public internet. The
# orchestrator only attaches `--network <name>`; building/enforcing the firewall is
# a deploy step. Required when TOOL_CODE_EXEC=true; without it the tool fails
# closed and is not advertised. The OFFLINE lane always uses `--network none`
# regardless of this value.
CODE_EXEC_NETWORK=
# Warm containers kept ready, and the max concurrent executions.
CODE_EXEC_POOL_SIZE=2
# Per-run wall-clock timeout (seconds).
CODE_EXEC_TIMEOUT_S=30
# Per-run hard resource caps. `--cpus` is a ceiling, not a reservation; idle
# pooled containers consume nothing, so worst-case load is POOL_SIZE × CPUS.
CODE_EXEC_MEMORY=256m
CODE_EXEC_CPUS=2.0
CODE_EXEC_PIDS_LIMIT=128
# User the code runs as inside the container (nobody:nogroup).
CODE_EXEC_USER=65534:65534
# Caps: captured stdout+stderr folded into the tool result, and accepted source size.
CODE_EXEC_OUTPUT_CHARS=16000
CODE_EXEC_MAX_CODE_BYTES=262144

# ---- Image tools (ComfyUI). Generation and editing are separate tools, each
# ---- with its own toggle + API-format workflow. Either is disabled unless its
# ---- toggle is on AND its workflow (+ required node mappings) are configured.
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_TIMEOUT_S=120
# Reject a returned image larger than this many bytes (default 16 MiB).
COMFYUI_MAX_IMAGE_BYTES=16777216

# ---- Server-hosted image delivery (optional). When IMAGE_STORE_DIR is set,
# ---- generated/edited images are persisted and handed to the app as signed
# ---- URL references (/v1/images/<id>) instead of inline base64, so re-sent
# ---- history stays small. Unset => images stay inline (back-compat).
# IMAGE_STORE_DIR=/var/lib/phantasm/images
# How long a generated image is reachable (default 90 days): both the blob's
# on-disk lifetime and the signed URL's expiry — one lifetime, since a link to a
# pruned blob is useless. The edit tool reads the blob directly when editing a
# referenced image, and it backstops app deletes that never arrive. The
# unguessable content-hash id is the primary guard; the signature is defense-
# in-depth. The app caches image bytes locally on receipt, so it doesn't depend
# on the URL surviving.
IMAGE_STORE_TTL_S=7776000
# Public origin the app reaches this server at, for minting absolute image URLs.
# Unset => emit site-relative /v1/images/<id> (the app resolves against its base).
# PUBLIC_BASE_URL=https://phantasm.example

# Each input maps to a workflow node as `<node-id>.<input-key>` (the Key/Node
# pairs you'd set in Open WebUI). Width/height/seed are optional model args;
# when omitted, the workflow's own baked-in values are kept (seed randomized).
# The bundled workflows target the standard SD 1.5 checkpoint
# (v1-5-pruned-emaonly.safetensors); point these at any API-format workflow and
# adjust the node mappings to match — e.g. a Flux/SDXL/instruction-edit graph.
# To avoid durable image files, bundled workflows use PreviewImage, and
# Phantasm rewrites built-in SaveImage nodes to PreviewImage before submission.

# Generation (text -> image). Defaults match workflows/sd15_txt2img.json.
TOOL_IMAGE_GEN=false
COMFYUI_GEN_WORKFLOW=workflows/sd15_txt2img.json
COMFYUI_GEN_PROMPT=6.text
COMFYUI_GEN_NEGATIVE=7.text    # blank for guidance-distilled models (e.g. Flux)
COMFYUI_GEN_WIDTH=5.width
COMFYUI_GEN_HEIGHT=5.height
COMFYUI_GEN_SEED=3.seed

# Editing (user's attached image + instruction -> image). Output size is set by
# the workflow. Defaults match workflows/sd15_img2img.json (img2img: the prompt
# describes the desired result; a true instruction-edit model can replace it).
TOOL_IMAGE_EDIT=false
COMFYUI_EDIT_WORKFLOW=workflows/sd15_img2img.json
COMFYUI_EDIT_PROMPT=6.text
COMFYUI_EDIT_IMAGE=11.image    # the LoadImage node the uploaded image feeds into
COMFYUI_EDIT_SEED=3.seed

# ---- Logging ----
# json | text
LOG_FORMAT=text
# Log message content (off by default for privacy, NFR-O7).
LOG_MESSAGE_CONTENT=false
