# Rust
/orchestrator/target
**/*.rs.bk

# Runtime state
/orchestrator/phantasm-metrics.sqlite*

# Env / secrets
.env
*.env.local

# Cloudflare
.wrangler/

# iOS / Xcode
# Keep the app-level SwiftPM lockfile so Xcode Cloud can resolve packages with
# automatic dependency resolution disabled. All other generated project files
# remain ignored.
ios/Phantasm.xcodeproj/*
!ios/Phantasm.xcodeproj/project.xcworkspace/
ios/Phantasm.xcodeproj/project.xcworkspace/*
!ios/Phantasm.xcodeproj/project.xcworkspace/xcshareddata/
ios/Phantasm.xcodeproj/project.xcworkspace/xcshareddata/*
!ios/Phantasm.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
ios/Phantasm.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!ios/Phantasm.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
ios/build/
ios/build-device/
ios/DerivedData/
ios/.build/
**/.DS_Store
**/xcuserdata/
**/*.xcworkspace/xcuserdata/
.swiftpm/
ios/Packages/*/.build/
